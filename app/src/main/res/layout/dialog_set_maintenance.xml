<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="16dp">

    <!-- Icon + Title Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_maintenance"
            android:tint="@color/orange"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Set Maintenance Mode"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/darkGray" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This will disconnect any active user and place this wheelchair into maintenance mode."
        android:textSize="14sp"
        android:textColor="@color/gray"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp" />

    <!-- Message Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Maintenance message (optional)"
        app:boxStrokeColor="@color/orange"
        app:hintTextColor="@color/orange"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/maintenance_message_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:minLines="3"
            android:gravity="top"
            android:textSize="14sp"
            android:textColor="@color/darkGray" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_maintenance"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textColor="@color/gray"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            app:rippleColor="@color/lightGray" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_maintenance"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Set Maintenance"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/orange"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_maintenance"
            app:iconTint="@color/white"
            app:iconSize="16dp" />

    </LinearLayout>

</LinearLayout>
