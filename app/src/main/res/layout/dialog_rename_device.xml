<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="16dp">

    <!-- Icon + Title Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_edit"
            android:tint="@color/primaryColor"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rename Device"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/darkGray" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/rename_device_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter a new display name for this device."
        android:textSize="14sp"
        android:textColor="@color/gray"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp" />

    <!-- Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Device name"
        app:boxStrokeColor="@color/primaryColor"
        app:hintTextColor="@color/primaryColor"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/rename_device_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:textSize="14sp"
            android:textColor="@color/darkGray" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_rename"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textColor="@color/gray"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            app:rippleColor="@color/lightGray" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_rename"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Rename"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/primaryColor"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_check"
            app:iconTint="@color/white"
            app:iconSize="16dp" />

    </LinearLayout>

</LinearLayout>
