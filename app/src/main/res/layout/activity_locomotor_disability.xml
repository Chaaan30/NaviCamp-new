<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/drawer_layout"
    android:background="#F0F3FD">

    <!-- Main Content -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- App Bar with Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                android:title="Locomotor Disability"
                android:titleTextColor="@android:color/white" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Main Screen Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome!"
                android:textSize="16sp"
                android:textColor="#000000"
                android:fontFamily="@font/inter_bold"/>

            <TextView
                android:id="@+id/user_fullname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Full Name!"
                android:textColor="#000000"
                android:textSize="20sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="\n\Would You like to ask for assistance today?"
                android:textColor="#000000"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/connection_status_textview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not connected to a wheelchair"
                android:textSize="16sp"
                android:textColor="#000000"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <!-- Line Follower Control Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/line_follower_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_location"
                        android:tint="@color/primaryColor"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Line Follower"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryColor"
                            android:fontFamily="@font/inter_bold" />

                        <TextView
                            android:id="@+id/line_follower_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IR sensors disabled"
                            android:textSize="14sp"
                            android:textColor="@color/darkGray"
                            android:fontFamily="@font/inter"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/line_follower_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:enabled="false"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/gray" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Container for images and buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <!-- First Image and Button -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="130dp"
                     android:layout_height="150dp"
                     android:src="@drawable/assistance_image"
                     android:scaleType="centerCrop"
                     android:background="@drawable/rounded_logo_background"
                        android:clipToOutline="true" />

                    <Button
                        android:id="@+id/assistance_button"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Ask for assistance"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_filled"
                        android:textColor="@color/onPrimaryColor"
                        android:textSize="10dp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

                <!-- Second Image and Button -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp">

                    <ImageView
                        android:layout_width="130dp"
                        android:layout_height="150dp"
                        android:src="@drawable/assistance_connect"
                        android:scaleType="centerCrop"
                        android:background="@drawable/rounded_logo_background"
                        android:clipToOutline="true" />

                    <Button
                        android:id="@+id/assistance_connect_button"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Connect to Wheelchair"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/button_filled"
                        android:textColor="@color/onPrimaryColor"
                        android:textSize="10dp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/primaryColor"
        android:fontFamily="@font/inter"
        app:headerLayout="@layout/nav_header"
        app:itemTextColor="@color/onPrimaryColor"
        app:menu="@menu/drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
