<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F3FD">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- USE A SCROLLVIEW SO CONTENT DOESN'T CUT OFF ON SMALL SCREENS -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="100dp"> <!-- Leaves space for BottomNav -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 1. HEADER SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:fontFamily="@font/inter_medium"
                    android:text="Hello,"
                    android:textColor="#1F2020"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/user_fullname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="Full Name!"
                    android:textColor="#1F2020"
                    android:textSize="25sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25sp"
                    android:fontFamily="@font/inter_bold"
                    android:gravity="center"
                    android:text="Emergency help needed?"
                    android:textColor="#1F2020"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/instruction_text"
                    android:layout_width="319dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:text="Press and hold the button below for 5 seconds to alert a safety officer in the campus"
                    android:textColor="#575757"
                    android:textSize="14sp" />

                <!-- 2. SOS BUTTON SECTION (Wrapped in FrameLayout to stack background and button) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="20dp">

                    <Button
                        android:id="@+id/assistance_button_background"
                        android:layout_width="286dp"
                        android:layout_height="286dp"
                        android:layout_gravity="center"
                        android:background="@drawable/assist_button_rounded_background"
                        app:backgroundTint="#E9C7CD" />

                    <Button
                        android:id="@+id/assistance_button"
                        android:layout_width="174dp"
                        android:layout_height="174dp"
                        android:layout_gravity="center"
                        android:background="@drawable/assist_button_rounded_background"
                        android:fontFamily="sans-serif-black"
                        android:text="SOS"
                        android:textColor="@color/onPrimaryColor"
                        android:textSize="50sp"
                        app:backgroundTint="#EE2D4C" />
                </FrameLayout>

                <!-- 3. CONNECTION STATUS (Now below SOS button) -->
                <TextView
                    android:id="@+id/connection_status_textview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:text="Not connected to a wheelchair"
                    android:textColor="#8C8C8C"
                    android:textSize="14sp" />

                <!-- 4. EXPIRY SECTION (Now below status text) -->
                <LinearLayout
                    android:id="@+id/expiry_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/expiry_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="Access Expiry"
                        android:textColor="#1F2020"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/expiry_date_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:text="Your temporary access expires on:\n[Date]"
                        android:textColor="#575757"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- FLOATING OVERLAYS (Banner and Nav) -->
        <LinearLayout
            android:id="@+id/emergency_contact_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="100dp"
            android:background="#EE2D4C"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:text="Kindly set your emergency contact person\nin the account settings"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_gravity="bottom"
            android:background="?android:attr/windowBackground"
            android:paddingTop="8dp"
            android:paddingBottom="15dp"
            app:menu="@menu/bottom_navigation_menu_pwd" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/primaryColor"
        android:fitsSystemWindows="true"
        android:fontFamily="@font/inter"
        app:headerLayout="@layout/nav_header"
        app:itemTextColor="@color/onPrimaryColor"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>