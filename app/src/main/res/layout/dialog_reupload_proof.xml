<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/rounded_dialog_background"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reupload Proof of Disability"
        android:textSize="18sp"
        android:fontFamily="@font/inter_bold"
        android:textColor="#000000"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/upload_proof_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Proof"
            android:textColor="@color/custom_blue"
            android:background="@drawable/button_outline"/>

        <ImageButton
            android:id="@+id/info_button_login"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/info"
            android:contentDescription="Info"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/selected_image_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No file selected" />

        <ImageButton
            android:id="@+id/remove_image_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true" />
    </LinearLayout>

    <Button
        android:id="@+id/confirm_upload_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirm Upload"
        android:layout_marginTop="16dp"
        android:background="@drawable/button_filled"/>
</LinearLayout>