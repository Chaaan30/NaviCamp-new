<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/backgroundColor">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_bold"
        android:text="Verification QR"
        android:textColor="@color/darkGray"
        android:textSize="24sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/inter"
        android:text="Select verification type, then generate and present this QR to the user."
        android:textColor="@color/gray"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/inter_bold"
        android:text="Verification Type"
        android:textColor="@color/gray"
        android:textSize="13sp" />

    <Spinner
        android:id="@+id/qr_role_spinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/spinner_background_with_arrow"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:popupBackground="@android:color/white"
        android:spinnerMode="dropdown" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/generate_qr_button"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:text="Generate QR"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:fontFamily="@font/inter_bold"
        android:backgroundTint="@color/primaryColor"
        app:cornerRadius="10dp" />

    <ImageView
        android:id="@+id/generated_qr_image"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:background="@android:color/white"
        android:contentDescription="Generated verification QR"
        android:padding="12dp" />

    <TextView
        android:id="@+id/generated_qr_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/inter"
        android:gravity="center"
        android:textColor="@color/gray"
        android:textSize="12sp" />

</LinearLayout>
